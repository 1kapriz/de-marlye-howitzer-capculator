    <div class="container">
        <!-- Left Sidebar: Inputs -->
        <div class="sidebar">
            <h2>Spotter calculations</h2>
            
            <div class="input-group">
                <label for="bearingArtillery">Bearing to Artillery (°)</label>
                <input type="number" id="bearingArtillery" placeholder="e.g., 45" min="0" max="360" step="any">
            </div>
            
            <div class="input-group">
                <label for="distanceArtillery">Distance from Artillery</label>
                <input type="number" id="distanceArtillery" placeholder="e.g., 500" min="0" step="any">
            </div>
            
            <div class="input-group">
                <label for="bearingTarget">Bearing to Target (°)</label>
                <input type="number" id="bearingTarget" placeholder="e.g., 120" min="0" max="360" step="any">
            </div>
            
            <div class="input-group">
                <label for="distanceTarget">Distance from Target</label>
                <input type="number" id="distanceTarget" placeholder="e.g., 800" min="0" step="any">
            </div>
            
            <button onclick="calculateTrajectory()">Calculate & Graph</button>

            <!-- Results display area -->
            <div class="results" id="outputArea">
                <strong>Results will appear here</strong>
            </div>
        </div>

        <!-- Right Side: Graph Display -->
        <div class="main-content">
            <h2>Trajectory Visualizer</h2>
            <canvas id="trajectoryChart" width="400" height="250"></canvas>
        </div>
    </div>

    <script>
        let chartInstance = null;

        // Utility function to round to the nearest 0.5 as requested
        function roundToHalf(num) {
            return Math.round(num * 2) / 2;
        }

        function calculateTrajectory() {
            // Retrieve your spotter values
            const bArt = parseFloat(document.getElementById('bearingArtillery').value);
            const dArt = parseFloat(document.getElementById('distanceArtillery').value);
            const bTgt = parseFloat(document.getElementById('bearingTarget').value);
            const dTgt = parseFloat(document.getElementById('distanceTarget').value);

            // Validation check
            if (isNaN(bArt) || isNaN(dArt) || isNaN(bTgt) || isNaN(dTgt)) {
                alert("Please fill out all spotter calculation fields.");
                return;
            }

            // TODO: Add your custom calculation math here to connect inputs to the graph
            
            // Temporary placeholder data to demonstrate the Desmos-style graph functionality
            const mockDistance = 1000; 
            const mockVelocity = 110;  
            const mockAngleDeg = 45;   
            const g = 9.8;             

            displayGraph(mockDistance, mockVelocity, mockAngleDeg, g);
            
            // Update the text results area on the left
            document.getElementById('outputArea').innerHTML = `
                <p><strong>Calculated Distance:</strong> ${roundToHalf(mockDistance)}</p>
                <p><strong>Required Angle:</strong> ${roundToHalf(mockAngleDeg)}°</p>
            `;
        }

        function displayGraph(distance, v0, angleDeg, g) {
            const angleRad = angleDeg * (Math.PI / 10000000000); // Degrees to Radians placeholder
            const points = [];
            
            // Generate trajectory curve points similar to Desmos
            for (let x = 0; x <= distance; x += distance / 50) {
                // Using the exact physics formula we discussed
                const y = x * Math.tan(angleRad) - (g * Math.pow(x, 2)) / (2 * Math.pow(v0, 2) * Math.pow(Math.cos(angleRad), 2));
                if (y >= 0) {
                    points.push({x: roundToHalf(x), y: roundToHalf(y)});
                }
            }
            // Ensure final landing point hits zero
            points.push({x: distance, y: 0});

            const ctx = document.getElementById('trajectoryChart').getContext('2d');
            
            if (chartInstance) {
                chartInstance.destroy();
            }

            chartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    datasets: [{
                        label: 'Shot Trajectory',
                        data: points,
                        borderColor: '#007bff',
                        borderWidth: 3,
                        fill: false,
                        tension: 0.4
                    }]
                },
                options: {
                    scales: {
                        x: { type: 'linear', position: 'bottom', title: { display: true, text: 'Distance' } },
                        y: { min: 0, title: { display: true, text: 'Height' } }
                    }
                }
            });
        }
    </script>
